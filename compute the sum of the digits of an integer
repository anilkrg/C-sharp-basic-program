class program
{
static void Main(string[] args)
{
            int n,temp,sum=0;
            Console.WriteLine("Enter your no.");
            n = int.Parse(Console.ReadLine());
            while (n > 0)
            {
                temp=n % 10;
                sum = sum + temp;
                n = n / 10;

            }
            Console.WriteLine(sum);
            Console.ReadKey();
}
