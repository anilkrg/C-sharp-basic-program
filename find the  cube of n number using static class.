static class Student
    {
        public static int i, n;
        public static void cube()
        {
            Console.WriteLine("Enter the number");
            n = int.Parse(Console.ReadLine());
            
            for(i=1;i<=n;i++)
            {
                Console.WriteLine("cube of {0} = {1}", i, i * i * i);
            }
            
        }
        static void Main(string[] args)
        {
            Student.cube();
               Console.ReadKey();
       }
        
        }
